import Base from '../../layouts/Base.astro';
---
<Base title="Kaiju Defense">
  <p class="meta"><a href="/projects/">← Projects</a></p>
  <h1>Kaiju Defense</h1>
  <p><span class="badge growing">in build</span></p>
  <p>
    A modern spiritual successor to the SNES classic Metal Marines. An alien hive crashed
    into the Pacific and is growing across an island. Build up a defense force, carve the
    hive back with missiles, and hold the line.
  </p>
  <ul>
    <li>The hive grows out in the open, no hidden head starts. What you scout is what's there.</li>
    <li>Base building and missile strikes are playable now. Mech drop counter-assaults are next on the build plan.</li>
    <li>Godot, browser-playable when it ships. Free, with a donation link.</li>
  </ul>
  <p>Build notes are in the <a href="/log/">devlog</a> as they happen.</p>
</Base>
