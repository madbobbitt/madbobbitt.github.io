---
import Base from '../../layouts/Base.astro';
---
<Base title="Quest Planner">
  <p class="meta"><a href="/projects/">← Projects</a></p>
  <h1>Quest Planner</h1>
  <p><span class="badge growing">in build</span></p>
  <p>
    A gamified take on the classic Franklin day planner for iOS. Plan the day, run the day,
    review the day. A cast of characters as the interface, and an evolution path that
    rewards the habit, not the streak anxiety.
  </p>
  <ul>
    <li>Local-first: your data stays on the device (SQLite, no cloud, no account).</li>
    <li>One-time purchase. No subscription, no ads, no dark patterns.</li>
    <li>React Native, iOS first.</li>
  </ul>
  <p>Build notes will appear in the <a href="/log/">devlog</a> as they happen.</p>
</Base>
