---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const entries = await getCollection('log');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d) => d.toISOString().slice(0, 10);
---
<Base title={entry.data.title}>
  <p class="meta">
    <a href="/log/">← Devlog</a> · {fmt(entry.data.date)}
    {entry.data.project ? ` · ${entry.data.project}` : ''}
    <span class={`badge ${entry.data.stage}`}>{entry.data.stage}</span>
  </p>
  <h1>{entry.data.title}</h1>
  <Content />
</Base>
